{
  "data_dir": "./data",
  "num_classes": 10,
  "batch_size": 64,
  "num_workers": 4,
  "model_name": "SimpleCNN",
  "use_pretrained": false,
  "num_epochs": 50,
  "learning_rate": 0.001,
  "weight_decay": 0.0001,
  "momentum": 0.9,
  "lr_step_size": 20,
  "lr_gamma": 0.5,
  "use_gpu": false,
  "seed": 42,
  "output_dir": "./outputs",
  "save_interval": 10,
  "log_interval": 10,
  "visualize": true,
  "plot_style": "seaborn"
}